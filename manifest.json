{
	"manifest_version": 3,
	"name": "tronclass 16x",
	"version": "1.0.0",
	"description": "This can be used to automatically play Tronclass videos at 16x speed.",
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"permissions": [
		"activeTab",
		"scripting",
		"storage",
		"webNavigation",
		"notifications"
	],
	"host_permissions": [
		"http://*/*",
    	"https://*/*"
	],
	"action": {
		"default_title": "tronclass 16x",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png"
		}
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"]
		}
	]
}